{
  "name": "bookplay-prod",
  "version": "1.0.0",
  "description": "Firebase Authentication을 사용한 BookPlay 웹 애플리케이션",
  "main": "public/index.html",
  "scripts": {
    "start": "cd public && python -m http.server 8000",
    "serve": "cd public && npx serve -s . -p 8000",
    "dev": "cd public && python -m http.server 8080",
    "build": "cd functions && npm run build",
    "deploy": "firebase deploy --only hosting",
    "preview": "firebase serve --only hosting"
  },
  "keywords": [
    "firebase",
    "authentication",
    "bookplay",
    "static-site",
    "javascript"
  ],
  "author": "BookPlay Team",
  "license": "MIT",
  "devDependencies": {
    "firebase-tools": "^12.0.0"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/bookplay-prod.git"
  },
  "bugs": {
    "url": "https://github.com/your-username/bookplay-prod/issues"
  },
  "homepage": "https://bookplay-production.web.app"
}
